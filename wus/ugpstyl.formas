        INPUT.btnborrar {
          font-family:         Arial,helvetica,sans-serif;
          font-weight:         normal;
          font-style:          normal;
          font-size:           11;
          color:               #000080;
          /*width:               64;
          height:              20;*/
          background-color:    #E6F0E3;
          border:              1px;
          border-color:        #4682B4;
          border-style:        solid;
          cursor:              hand;
        }


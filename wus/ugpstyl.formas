        TEXTAREA {
          font-family:      Arial,helvetica,sans-serif;
          font-size:            12;
          color:                #000080;
          background-color:     #E9E8E7;
          border:               solid 1px #B0C4DE;
        }

        TABLE {
          border-style: solid;
          border-width:  0.01cm;
          border-color:  #C0C0C0;
          background:    #FFFFFF;
        }

        TABLE.sinborde {
          border-style: solid;
          border-width:  0.00cm;
          border-color:  #FFFFFF;
          background:    #FFFFFF;
        }

        TABLE.bordeazul {
          border-style: solid;
          border-width:  0.01cm;
          border-color:  #336699;
          background:    #FFFFFF;
        }

        TABLE.fixbordeazul {
          border-style: solid;
          border-width:  0.01cm;
          border-color:  #336699;
          background:    #FFFFFF;
          table-layout:  fixed;
        }


        .botonEntra {Border:"1px solid #990000"; background-color:"#FFEA97"}
        .boton1Default {Border:"1px solid #83a3d2"; background-color:"#e5e5e5"}
        .boton2Default {Border:"1px solid #83a3d2"; background-color:"#e5e5e5"}
  
